NODE_ENV=development
PORT=5000
SEED_ADMIN_EMAIL=admin@internops.com
SEED_ADMIN_PASSWORD=Admin@123
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
DATABASE_URL=postgresql://user:password@host/dbname
CORS_ORIGIN=http://localhost:5173
GROQ_API_KEY=your-groq-key
GEMINI_API_KEY=your-gemini-key
UPSTASH_REDIS_REST_URL=your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token
APP_URL=http://localhost:5173

# API versioning — activate when v1 enters its sunset window (≥ 90 days notice)
# V1_DEPRECATED=true
# V1_DEPRECATION_DATE=Sat, 01 Jan 2028 00:00:00 GMT
# V1_SUNSET_DATE=Mon, 01 Apr 2028 00:00:00 GMT

# ERROR TRACKING (Sentry — optional, set DSN to enable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
